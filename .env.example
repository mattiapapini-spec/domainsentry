# DomainSentry — Environment Variables
# Copia questo file in .env e configura i valori

# API Keys (opzionali — graceful degradation se vuoti)
VT_API_KEY=
OTX_API_KEY=
ST_API_KEY=

# Webhook (Slack/Teams)
WEBHOOK_URL=

# ── Case Manager (opt-in: gestione SOC + auth) ──
# Attiva il servizio di case management con autenticazione strutturata
ENABLE_CASE_MANAGER=false
ADMIN_USERNAME=admin
# Se vuoto, viene generata una password casuale loggata all'avvio
ADMIN_PASSWORD=

# ── Feed write auth (opt-in) ──
# Protegge gli endpoint di scrittura del feed (POST/DELETE) richiedendo
# un token valido. Richiede ENABLE_CASE_MANAGER=true.
# Le letture restano sempre aperte.
FEED_REQUIRE_AUTH=false

# ── Auto case ingestion (opt-in) ──
# When true, every pipeline event becomes a manageable case in the case-manager,
# visible in the dashboard. Requires ENABLE_CASE_MANAGER=true.
# SERVICE_TOKEN is a long random secret for service-to-service auth — generate
# with: openssl rand -hex 32
CASE_INGEST=false
SERVICE_TOKEN=

# ── Intelligence persistence (opt-in) ──
# Store full per-domain intel snapshot + baseline diff history, shown in the
# dashboard Intelligence tab. Snapshot overwrites; diff history accrues deltas.
INTEL_STORE=false

# ── Security hardening (optional; safe defaults) ──
# SSRF protection: block outbound requests to internal IPs. Keep 'true' in production.
SSRF_PROTECTION=true
# Login rate limiting: max failed attempts per IP within the window (seconds).
LOGIN_MAX_FAILURES=5
LOGIN_WINDOW_SEC=300
